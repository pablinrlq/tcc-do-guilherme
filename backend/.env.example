# Banco de dados SQLite (caminho relativo à pasta prisma/)
DATABASE_URL="file:./dev.db"

# Autenticação JWT — gere um segredo forte em produção
JWT_SECRET="troque-por-um-segredo-forte"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3333
NODE_ENV="development"

# Uploads
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=5

# CORS — origem do frontend
CLIENT_URL="http://localhost:5173"
